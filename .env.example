DJANGO_SECRET_KEY=replace-this-with-a-long-random-secret
DJANGO_SETTINGS_MODULE=config.settings.development
DEBUG=True
TIME_ZONE=Africa/Dar_es_Salaam
DATABASE_URL=postgres://disciplinetrack_user:password@localhost:5432/disciplinetrack_db
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
MEDIA_ROOT=media
MEDIA_URL=/media/

# SMS_PROVIDER=console just logs messages (default, no credentials needed).
# Set to "sendafrica" and fill these in once the real send endpoint/payload
# are confirmed against the SendAfrica docs (see apps/notifications/providers.py).
SMS_PROVIDER=console
SENDAFRICA_API_KEY=
SENDAFRICA_BASE_URL=https://api.sendafrica.online
SENDAFRICA_SENDER_ID=
